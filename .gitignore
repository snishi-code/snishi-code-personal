# macOS
.DS_Store
.AppleDouble
.LSOverride

# Build output (Cloudflare Pages が生成するのでコミット不要)
dist/
dist-site/
*.tsbuildinfo

# npm
node_modules/

# Playwright / test output
test-results/
playwright-report/
.playwright/

# 環境変数 (現状不使用だが念のため)
.env
.env.local
.env.*.local

# エディタ
.vscode/
.idea/
.obsidian/

# ログ
*.log
npm-debug.log*

# 説明書 Obsidian vault (docs/<app>/)
#   - *.md は git 管理（下書き〜清書をバージョン管理する）
#   - images/ は gitignore：配信用コピーが各アプリの public/docs-images/ に
#     git 管理されているため、スクショを git に二重保存しない
#   - .obsidian/ は上の「エディタ」セクションで既に除外済み
docs/*/images/

# 患者データエクスポートJSON（タイトル_YYYY_MMDD_HHMM.json 形式）
# 日本語タイトルも含めてタイムスタンプパターンで除外
*_[0-9][0-9][0-9][0-9]_[0-9][0-9][0-9][0-9]_[0-9][0-9][0-9][0-9].json

# Claude Code session data
.claude/*
!.claude/agents/

# 旧 agent handoff 運用は廃止済み（_agent-handoff/ は使わない）。旧名のフォルダや
# 作業メモを誤ってコミットしないよう保険で除外する（指示書・作業報告・監査メモは push しない）。
_agent-handoff/
.agent-handoff/
agent-handoff/
current-task.md
claude-report.md
audit-note.md
